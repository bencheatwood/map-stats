{
  "name": "hltv",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./src/app/*.tsx",
    "#ui/*": "./src/components/ui/*.tsx",
    "#components/*": "./src/components/*.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "version": "git add .",
    "postversion": "pn i --lockfile-only && git push --follow-tags",
    "patch": "pn version patch -no-git-checks -m ",
    "betaminor": "pn version preminor --preid=beta -no-git-checks -m ",
    "minor": "pn version minor -no-git-checks -m ",
    "major": "pn version major -no-git-checks -m ",
    "prepare": "vp config",
    "up": "pn self-update && pn update -L",
    "predeploy": "vp build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@voidzero-dev/vite-plus-core": "^0.1.24",
    "@voidzero-dev/vite-plus-test": "^0.1.24",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "gh-pages": "^6.3.0",
    "oxc-transform": "^0.134.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.5.2"
}